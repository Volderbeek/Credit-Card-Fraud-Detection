# .gcloudignore
# Specifies files to ignore when uploading to Google Cloud Build

.gcloudignore
.git
.gitignore

# Ignore raw data files (large CSVs)
*.csv
fraudTest.csv
fraudTrain.csv

# Ignore local python virtual environments and cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/env/
**/venv/
**/.venv/
**/.conda/

# Ignore frontend dependencies and build output
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Explicitly ensure model.onnx is included
!model.onnx
